# Supabase server-side access. Never expose the service role key in the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Used only by `npm run db:push -- --db-url "$SUPABASE_DB_URL"`.
# Keep this server-side and never expose it as NEXT_PUBLIC_*.
SUPABASE_DB_URL=postgresql://postgres:percent-encoded-password@your-host:5432/postgres

# Optional admin token for DELETE /api/reports when you need to clear database cases.
ADMIN_API_TOKEN=replace-with-a-long-random-token
DRONE_GATEWAY_TOKEN=replace-with-a-long-random-token-for-drone-gateway
WATER_INGEST_TOKEN=replace-with-the-same-or-another-token-for-old-pi-water-yolo

# Optional YOLO service. POST /api/reports sends image multipart field `image` to this endpoint.
YOLO_API_URL=http://127.0.0.1:8010/detect-water-level
YOLO_API_KEY=
NEXT_PUBLIC_YOLO_STATUS=Ready for YOLO API results

# Used by tools/yolo-water-service/server.py
YOLO_MODEL_PATH=tools/yolo-water-service/models/flood_water_level.pt
YOLO_CONF=0.25
YOLO_REFERENCE_LABELS=utility_pole,electric_pole,power_pole,pole,water_level_gauge,water_gauge,staff_gauge,gauge_board,level_staff,water_staff,flood_gauge,ruler,staff,gauge,reference_marker,marker
WATER_REFERENCE_HEIGHT_CM=900
WATER_GAUGE_REFERENCE_HEIGHT_CM=200
WATER_REFERENCE_TOP_Y=0
WATER_REFERENCE_BOTTOM_Y=720
