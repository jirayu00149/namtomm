{
  "name": "my-flood-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:push": "supabase db push",
    "db:advisors": "supabase db advisors",
    "preview": "node scripts/cloudflare.mjs preview",
    "deploy": "node scripts/cloudflare.mjs deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:build": "node scripts/cloudflare.mjs build",
    "yolo:install": "python -m pip install -r tools/yolo-water-service/requirements.txt",
    "yolo:train": "python tools/yolo-water-service/train.py",
    "yolo:train:quick": "python tools/yolo-water-service/train.py --epochs 20 --imgsz 416 --batch 1 --name flood_level_quick",
    "yolo:train:smoke": "python tools/yolo-water-service/train.py --epochs 1 --imgsz 320 --batch 1 --fraction 0.01 --name flood_level_smoke --exist-ok --no-copy",
    "yolo:service": "python tools/yolo-water-service/server.py"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.108.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.20.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "rclone.js": "0.6.6",
    "supabase": "2.108.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "4.105.0"
  }
}